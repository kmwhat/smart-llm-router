# Smart LLM Router configuration
# Copy this file to .env and fill keys locally. Never commit real API keys.

SMART_LLM_DATA_DIR=~/.smart-llm-router
SMART_LLM_TIMEOUT=45
SMART_LLM_EMPTY_POOL_REFRESH_TIMEOUT=5
SMART_LLM_EMPTY_POOL_REFRESH_LIMIT=8
SMART_LLM_AUTO_DISCOVER_FREE=true
SMART_LLM_DISCOVERY_TTL_HOURS=6
SMART_LLM_DISCOVERY_LIMIT=20
SMART_LLM_CACHE=true
SMART_LLM_CACHE_MAX_ITEMS=500
SMART_LLM_CNY_PER_USD=7.2
SMART_LLM_VISION_MAX_SIDE=1280
SMART_LLM_VISION_JPEG_QUALITY=82

# Experimental task descriptor v2. Default off. When enabled, it may change
# only non-role complexity labels; plan/execute/audit/verify/quality_enhance
# keep their original role quality floors. Set false or unset to roll back.
SMART_LLM_TASK_DESCRIPTOR_V2_ENABLED=false

OPENROUTER_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
DASHSCOPE_API_KEY=
ARK_API_KEY=
GEMINI_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=

# Keep Gemini in the restricted free tier unless billing has been explicitly
# enabled and verified for this installation.
SMART_LLM_GEMINI_PAID_ENABLED=false

# Current Ark online-inference candidates. Model-name access is account scoped;
# discover/probe them before production use. Endpoint ids stay separate.
SMART_LLM_DOUBAO_FRONTIER_MODELS=doubao-seed-2-1-pro,doubao-seed-2-1-turbo,doubao-seed-2-0-pro-260215,doubao-seed-2-0-code-preview-260215

# Free pool, benchmark-informed defaults.
SMART_LLM1_NAME=openrouter-deepseek-free
SMART_LLM1_BASE_URL=https://openrouter.ai/api/v1
SMART_LLM1_API_KEY_ENV=OPENROUTER_API_KEY
SMART_LLM1_MODELS=deepseek/deepseek-v4-flash:free
SMART_LLM1_FREE=true
SMART_LLM1_PRIORITY=1

SMART_LLM2_NAME=nvidia-free
SMART_LLM2_BASE_URL=https://integrate.api.nvidia.com/v1
SMART_LLM2_API_KEY_ENV=NVIDIA_API_KEY
SMART_LLM2_MODELS=nvidia/llama-3.3-nemotron-super-49b-v1,nvidia/llama-3.1-nemotron-nano-8b-v1,meta/llama-3.1-70b-instruct
SMART_LLM2_FREE=true
SMART_LLM2_BILLING_CLASS=trial_quota
SMART_LLM2_PRIORITY=2

SMART_LLM3_NAME=nvidia-google-free
SMART_LLM3_BASE_URL=https://integrate.api.nvidia.com/v1
SMART_LLM3_API_KEY_ENV=NVIDIA_API_KEY
SMART_LLM3_MODELS=google/gemma-4-31b-it,google/gemma-3n-e4b-it
SMART_LLM3_FREE=true
SMART_LLM3_BILLING_CLASS=trial_quota
SMART_LLM3_PRIORITY=3

SMART_LLM4_NAME=qwen-free
SMART_LLM4_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMART_LLM4_API_KEY_ENV=DASHSCOPE_API_KEY
SMART_LLM4_MODELS=qwen-turbo-latest,qwen-plus-latest
SMART_LLM4_FREE=true
SMART_LLM4_BILLING_CLASS=trial_quota
SMART_LLM4_PRIORITY=4

SMART_LLM5_NAME=doubao-free
SMART_LLM5_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SMART_LLM5_API_KEY_ENV=ARK_API_KEY
SMART_LLM5_MODELS=your-doubao-endpoint-id
SMART_LLM5_FREE=true
SMART_LLM5_BILLING_CLASS=trial_quota
SMART_LLM5_PRIORITY=5

SMART_LLM6_NAME=openrouter-router-free
SMART_LLM6_BASE_URL=https://openrouter.ai/api/v1
SMART_LLM6_API_KEY_ENV=OPENROUTER_API_KEY
SMART_LLM6_MODELS=openrouter/free
SMART_LLM6_FREE=true
SMART_LLM6_PRIORITY=6

SMART_LLM7_NAME=groq-free
SMART_LLM7_BASE_URL=https://api.groq.com/openai/v1
SMART_LLM7_API_KEY_ENV=GROQ_API_KEY
SMART_LLM7_MODELS=llama-3.1-8b-instant
SMART_LLM7_FREE=true
SMART_LLM7_PRIORITY=8

SMART_LLM8_NAME=openrouter-google-free
SMART_LLM8_BASE_URL=https://openrouter.ai/api/v1
SMART_LLM8_API_KEY_ENV=OPENROUTER_API_KEY
SMART_LLM8_MODELS=google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free
SMART_LLM8_FREE=true
SMART_LLM8_PRIORITY=9

SMART_LLM11_NAME=openrouter-vision-free
SMART_LLM11_BASE_URL=https://openrouter.ai/api/v1
SMART_LLM11_API_KEY_ENV=OPENROUTER_API_KEY
SMART_LLM11_MODELS=nvidia/nemotron-nano-12b-v2-vl:free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free
SMART_LLM11_FREE=true
SMART_LLM11_PRIORITY=1

SMART_LLM12_NAME=nvidia-vision-free
SMART_LLM12_BASE_URL=https://integrate.api.nvidia.com/v1
SMART_LLM12_API_KEY_ENV=NVIDIA_API_KEY
SMART_LLM12_MODELS=nvidia/nemotron-nano-12b-v2-vl,nvidia/llama-3.1-nemotron-nano-vl-8b-v1,meta/llama-3.2-11b-vision-instruct,microsoft/phi-4-multimodal-instruct,google/gemma-4-31b-it
SMART_LLM12_FREE=true
SMART_LLM12_PRIORITY=2

# Gemini free tier. Use only for public/non-sensitive content; free-tier input
# may be used by Google to improve products and has lower rate limits.
SMART_LLM9_NAME=gemini-free
SMART_LLM9_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SMART_LLM9_API_KEY_ENV=GEMINI_API_KEY
SMART_LLM9_MODELS=gemini-2.5-pro,gemini-2.5-flash-lite
SMART_LLM9_FREE=true
SMART_LLM9_BILLING_CLASS=trial_quota
SMART_LLM9_PRIORITY=2

SMART_LLM10_NAME=openrouter-deepseek-fallback
SMART_LLM10_BASE_URL=https://openrouter.ai/api/v1
SMART_LLM10_API_KEY_ENV=OPENROUTER_API_KEY
SMART_LLM10_MODELS=deepseek/deepseek-v4-flash
SMART_LLM10_FREE=false
SMART_LLM10_PRIORITY=10

SMART_LLM14_NAME=zhipu-glm-lowcost
SMART_LLM14_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SMART_LLM14_API_KEY_ENV=ZHIPU_API_KEY
SMART_LLM14_MODELS=glm-5,glm-4.7,glm-5-turbo,glm-5.2
SMART_LLM14_FREE=false
SMART_LLM14_PRIORITY=8

SMART_LLM16_NAME=zhipu-embedding-lowcost
SMART_LLM16_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SMART_LLM16_API_KEY_ENV=ZHIPU_API_KEY
SMART_LLM16_MODELS=embedding-3,embedding-2
SMART_LLM16_FREE=false
SMART_LLM16_PRIORITY=8

SMART_LLM17_NAME=zhipu-rerank-lowcost
SMART_LLM17_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SMART_LLM17_API_KEY_ENV=ZHIPU_API_KEY
SMART_LLM17_MODELS=rerank
SMART_LLM17_FREE=false
SMART_LLM17_PRIORITY=8

SMART_LLM18_NAME=qwen-embedding-lowcost
SMART_LLM18_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMART_LLM18_API_KEY_ENV=DASHSCOPE_API_KEY
SMART_LLM18_MODELS=text-embedding-v4,text-embedding-v3
SMART_LLM18_FREE=false
SMART_LLM18_PRIORITY=8

SMART_LLM19_NAME=qwen-rerank-lowcost
SMART_LLM19_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SMART_LLM19_API_KEY_ENV=DASHSCOPE_API_KEY
SMART_LLM19_MODELS=gte-rerank
SMART_LLM19_FREE=false
SMART_LLM19_PRIORITY=8
# Enable only after your DashScope account has rerank permission and
# `refresh-modalities --tasks rerank --families qwen --include-paid` passes.

# Optional Zhipu vision/OCR chat-compatible block. Enable only after a small
# refresh-modalities probe confirms your account and endpoint can call these models.
# SMART_LLM15_NAME=zhipu-vision-lowcost
# SMART_LLM15_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# SMART_LLM15_API_KEY_ENV=ZHIPU_API_KEY
# SMART_LLM15_MODELS=glm-5v-turbo,glm-4.6v,glm-4v-flash,glm-ocr
# SMART_LLM15_FREE=false
# SMART_LLM15_PRIORITY=8

# Zhipu provider-family capability notes: the same ZHIPU_API_KEY may also cover
# image generation (glm-image/cogview), video generation (cogvideo/vidu),
# speech/audio (glm-tts/glm-asr/glm-realtime), embedding, and rerank models.
# Those specialized modes need provider-specific adapters before being enabled
# as executable SMART_LLM blocks; capabilities/route-plan can still list them.

# Optional cost ledger pricing. Unit: USD per 1M tokens.
# Built-in list-price estimates cover DeepSeek V4, Qwen 3.7 Max/Plus,
# GLM-5.2, Kimi K3, Gemini Pro, and Doubao Seed 2.1/2.0 Pro. Environment
# overrides take precedence when account pricing differs.
# SMART_LLM_PRICE_OPENROUTER_DEEPSEEK_FALLBACK_INPUT=0.07
# SMART_LLM_PRICE_OPENROUTER_DEEPSEEK_FALLBACK_OUTPUT=0.28
# SMART_LLM_PRICE_GEMINI_FRONTIER_PAID_INPUT=
# SMART_LLM_PRICE_GEMINI_FRONTIER_PAID_OUTPUT=
# SMART_LLM_PRICE_ZHIPU_GLM_LOWCOST_INPUT=
# SMART_LLM_PRICE_ZHIPU_GLM_LOWCOST_OUTPUT=
